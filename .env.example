# N8N Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_PORT=5678
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-min-24-chars-12345678

# Backend Configuration
MONGODB_URI=mongodb://mongo:27017/waf-automation
ZAP_BASE_URL=http://zap:8080
ZAP_API_KEY=changeme
